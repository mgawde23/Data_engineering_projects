    import dlt
from pyspark.sql.functions import col, current_timestamp

@dlt.table(
    name="silver_sensor_data",
    comment="Cleaned and validated sensor data"
)
# 1. 'expect' -> Records the failure but keeps the data (Warning)
@dlt.expect("valid_timestamp", "timestamp IS NOT NULL")

# 2. 'expect_or_drop' -> Removes the bad record entirely (Cleaning)
@dlt.expect_or_drop("valid_temperature", "temperature BETWEEN -50 AND 100")
@dlt.expect_or_drop("valid_humidity", "humidity BETWEEN 0 AND 100")

# 3. 'expect_or_fail' -> Stops the pipeline if this fails (Critical)
@dlt.expect_or_fail("valid_device_id", "device_id IS NOT NULL")

def silver_sensor_data():
    return (
        dlt.read_stream("bronze_sensor_data")
        .select(
            col("timestamp").cast("timestamp"),
            col("device_id").cast("string"),
            col("temperature").cast("double"),
            col("humidity").cast("double"),
            col("status").cast("string")
        )
        .withColumn("silver_cleansed_time", current_timestamp())
    )

import dlt
from pyspark.sql.functions import col, window, avg, max, min, count

@dlt.table(
    name="gold_sensor_stats_incremental",
    comment="Incremental minutely stats with a 2-minute late-data watermark"
)
def gold_sensor_stats_incremental():
    return (
        # 1. Read as a STREAM from Silver
        dlt.read("silver_sensor_data") 
        
        # 2. Define the Watermark (Wait 5 minutes for late data)
        #.withWatermark("timestamp", "2 minutes") 
        
        # 3. Group by Window and Device
        .groupBy(
            window(col("timestamp"), "1 minute"), 
            col("device_id")
        )
        
        # 4. Aggregate
        .agg(
            avg("temperature").alias("avg_temp"),
            count("*").alias("event_count")
        )
        
        # 5. Clean up the output columns
        .select(
            col("window.start").alias("window_start"),
            "device_id",
            "avg_temp",
            "event_count"
        )
    )




    
